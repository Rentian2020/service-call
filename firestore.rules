rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /serviceRequests/{reqId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (resource.data.providerOwnerUid == request.auth.uid) ||
        (resource.data.providerId == "unassigned" && resource.data.status == "pending")
      );

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null && (
        (resource.data.userId == request.auth.uid) ||
        (resource.data.providerOwnerUid != null && resource.data.providerOwnerUid == request.auth.uid) ||
        (resource.data.providerId == "unassigned"
          && request.resource.data.providerId != "unassigned"
          && request.resource.data.providerOwnerUid == request.auth.uid)
      );

      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
